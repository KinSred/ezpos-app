{
  "name": "ezpos",
  "author": "Tri Bảo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "electron:start": "concurrently -k \"npm run dev\" \"wait-on tcp:5173 && electron .\"",
    "electron:build:mac": "npm run build && electron-builder --mac --publish never",
    "electron:build:win": "npm run build && electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.ezpos.app",
    "productName": "EZPOS",
    "publish": {
      "provider": "github",
      "owner": "KinSred",
      "repo": "ezpos-app"
    },
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.business"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "autoprefixer": "^10.5.1",
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
    "electron-updater": "^6.8.9",
    "framer-motion": "^12.41.0",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^1.21.0",
    "pdf-to-printer": "^5.8.0",
    "peerjs": "^1.5.5",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hot-toast": "^2.6.0",
    "react-qr-code": "^2.2.0",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.9.0",
    "tailwindcss": "^4.3.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.69.0",
    "vite": "^8.1.0",
    "wait-on": "^9.0.10"
  }
}
